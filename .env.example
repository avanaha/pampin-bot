# MAX Bot API Token
MAX_BOT_TOKEN=your_bot_token_here

# Group ID for notifications (negative number)
GROUP_ID=-72385180944913

# Webhook URL (optional, for production)
WEBHOOK_URL=https://your-domain.com/webhook

# Port for server
PORT=3000

# Timezone for bot (default: Europe/Moscow)
TIMEZONE=Europe/Moscow

# Database path
DATABASE_PATH=./data/pampin.db

# Environment (development/production)
NODE_ENV=development
